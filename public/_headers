/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.exchangerate.host; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(self), geolocation=(), microphone=(), payment=(), usb=()
  X-DNS-Prefetch-Control: on

# Cache statique agressif pour les assets versionnes
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache court pour les icones PWA
/icons/*
  Cache-Control: public, max-age=86400

# Pas de cache pour le manifest et le service worker (toujours fresh)
/manifest.json
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate
